{
  "name": "pianospark",
  "version": "2.0.0",
  "description": "Piano chord learning app with progress tracking and stem separation",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "test": "node tests/test_core.js"
  },
  "author": "PianoSpark",
  "license": "MIT",
  "devDependencies": {
    "electron": "^33.4.11",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "com.pianospark.app",
    "productName": "PianoSpark",
    "mac": {
      "target": ["dmg"],
      "icon": "icon.png",
      "category": "public.app-category.music"
    },
    "win": {
      "target": ["nsis"],
      "icon": "icon.png"
    },
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "icon.png",
      "styles.css",
      "js/**/*",
      "piano_chords/**/*"
    ],
    "extraResources": [
      {
        "from": "resources/",
        "to": "resources/",
        "filter": ["**/*"]
      }
    ]
  }
}
